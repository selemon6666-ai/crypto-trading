<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Trading Simulator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 30px;
            font-size: 2.5rem;
        }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .card h3 {
            color: #333;
            margin-bottom: 15px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .balance {
            font-size: 2rem;
            color: #28a745;
            font-weight: bold;
        }

        .trade-form input, .trade-form select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 1rem;
        }

        button {
            width: 100%;
            padding: 12px;
            margin: 5px 0;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s;
        }

        button:hover {
            transform: translateY(-2px);
        }

        .btn-buy {
            background: #28a745;
            color: white;
        }

        .btn-sell {
            background: #dc3545;
            color: white;
        }

        .portfolio-item {
            display: flex;
            justify-content: space-between;
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .price-up {
            color: #28a745;
        }

        .price-down {
            color: #dc3545;
        }

        .market-data {
            max-height: 400px;
            overflow-y: auto;
        }

        .market-item {
            display: flex;
            justify-content: space-between;
            padding: 10px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
        }

        .market-item:hover {
            background: #f0f0f0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📈 Crypto Trading Simulator</h1>
        
        <div class="dashboard">
            <!-- Balance Card -->
            <div class="card">
                <h3>💰 Your Balance</h3>
                <div class="balance">$<span id="balance">10000</span></div>
                <div style="margin-top: 10px; color: #666;">
                    Net Worth: $<span id="netWorth">10000</span>
                </div>
            </div>

            <!-- Trading Form -->
            <div class="card">
                <h3>🔄 Trade Crypto</h3>
                <div class="trade-form">
                    <select id="cryptoSelect">
                        <option value="BTC">Bitcoin (BTC)</option>
                        <option value="ETH">Ethereum (ETH)</option>
                        <option value="BNB">Binance Coin (BNB)</option>
                        <option value="SOL">Solana (SOL)</option>
                        <option value="DOGE">Dogecoin (DOGE)</option>
                    </select>
                    <input type="number" id="price" placeholder="Current Price" readonly>
                    <input type="number" id="shares" placeholder="Amount to trade">
                    <button class="btn-buy" onclick="buy()">BUY</button>
                    <button class="btn-sell" onclick="sell()">SELL</button>
                </div>
            </div>

            <!-- Portfolio -->
            <div class="card">
                <h3>📊 Your Portfolio</h3>
                <div id="portfolioList">
                    <p style="color: #999;">No holdings yet</p>
                </div>
            </div>
        </div>

        <!-- Market Prices -->
        <div class="card">
            <h3>📡 Live Market Prices</h3>
            <div class="market-data" id="marketData">
                Loading prices...
            </div>
        </div>
    </div>

    <script>
        // Initial balance
        let balance = 10000;
        
        // Portfolio structure
        let portfolio = {};
        
        // Available cryptocurrencies with their current prices
        let marketPrices = {
            BTC: 0,
            ETH: 0,
            BNB: 0,
            SOL: 0,
            DOGE: 0
        };
        
        // Crypto full names
        const cryptoNames = {
            BTC: 'Bitcoin',
            ETH: 'Ethereum',
            BNB: 'Binance Coin',
            SOL: 'Solana',
            DOGE: 'Dogecoin'
        };
        
        // Simulate real-time price updates
        function updatePrices() {
            // Generate random price movements
            const basePrices = {
                BTC: 50000 + Math.random() * 5000,
                ETH: 3000 + Math.random() * 500,
                BNB: 400 + Math.random() * 50,
                SOL: 100 + Math.random() * 30,
                DOGE: 0.15 + Math.random() * 0.05
            };
            
            for (let crypto in marketPrices) {
                let oldPrice = marketPrices[crypto];
                let newPrice = basePrices[crypto];
                
                // Add some random volatility
                newPrice = newPrice * (0.98 + Math.random() * 0.04);
                marketPrices[crypto] = parseFloat(newPrice.toFixed(2));
            }
            
            updateMarketDisplay();
            updateCurrentPriceDisplay();
            updateNetWorth();
        }
        
        // Update the market prices display
        function updateMarketDisplay() {
            const marketDiv = document.getElementById('marketData');
            marketDiv.innerHTML = '';
            
            for (let [symbol, price] of Object.entries(marketPrices)) {
                const item = document.createElement('div');
                item.className = 'market-item';
                item.onclick = () => selectCrypto(symbol);
                
                const change = (Math.random() * 10 - 5).toFixed(2);
                const changeClass = change >= 0 ? 'price-up' : 'price-down';
                const changeSymbol = change >= 0 ? '▲' : '▼';
                
                item.innerHTML = `
                    <strong>${cryptoNames[symbol]} (${symbol})</strong>
                    <div>
                        <span>$${price.toFixed(2)}</span>
                        <span class="${changeClass}" style="margin-left: 10px;">${changeSymbol} ${Math.abs(change)}%</span>
                    </div>
                `;
                marketDiv.appendChild(item);
            }
        }
        
        // Update the price in the trade form when crypto is selected
        function updateCurrentPriceDisplay() {
            const selected = document.getElementById('cryptoSelect').value;
            const priceInput = document.getElementById('price');
            if (marketPrices[selected]) {
                priceInput.value = marketPrices[selected];
            }
        }
        
        // Select crypto from market list
        function selectCrypto(symbol) {
            document.getElementById('cryptoSelect').value = symbol;
            updateCurrentPriceDisplay();
        }
        
        // Update net worth calculation
        function updateNetWorth() {
            let holdingsValue = 0;
            for (let [symbol, amount] of Object.entries(portfolio)) {
                holdingsValue += amount * marketPrices[symbol];
            }
            const netWorth = balance + holdingsValue;
            document.getElementById('netWorth').innerText = netWorth.toFixed(2);
        }
        
        // Buy function
        function buy() {
            const symbol = document.getElementById('cryptoSelect').value;
            const price = parseFloat(document.getElementById('price').value);
            const amount = parseFloat(document.getElementById('shares').value);
            
            if (isNaN(amount) || amount <= 0) {
                alert('Please enter a valid amount');
                return;
            }
            
            const cost = price * amount;
            
            if (cost > balance) {
                alert(`Insufficient balance! You need $${cost.toFixed(2)} but only have $${balance.toFixed(2)}`);
                return;
            }
            
            // Deduct from balance
            balance -= cost;
            
            // Add to portfolio
            if (!portfolio[symbol]) {
                portfolio[symbol] = 0;
            }
            portfolio[symbol] += amount;
            
            // Update UI
            updateUI();
            alert(`✅ Bought ${amount} ${symbol} for $${cost.toFixed(2)}`);
            
            // Clear amount input
            document.getElementById('shares').value = '';
        }
        
        // Sell function
        function sell() {
            const symbol = document.getElementById('cryptoSelect').value;
            const price = parseFloat(document.getElementById('price').value);
            const amount = parseFloat(document.getElementById('shares').value);
            
            if (isNaN(amount) || amount <= 0) {
                alert('Please enter a valid amount');
                return;
            }
            
            if (!portfolio[symbol] || portfolio[symbol] < amount) {
                alert(`You don't have enough ${symbol} to sell! You have ${portfolio[symbol] || 0} ${symbol}`);
                return;
            }
            
            const revenue = price * amount;
            
            // Add to balance
            balance += revenue;
            
            // Remove from portfolio
            portfolio[symbol] -= amount;
            if (portfolio[symbol] === 0) {
                delete portfolio[symbol];
            }
            
            // Update UI
            updateUI();
            alert(`✅ Sold ${amount} ${symbol} for $${revenue.toFixed(2)}`);
            
            // Clear amount input
            document.getElementById('shares').value = '';
        }
        
        // Update the entire UI
        function updateUI() {
            // Update balance display
            document.getElementById('balance').innerText = balance.toFixed(2);
            
            // Update portfolio display
            const portfolioDiv = document.getElementById('portfolioList');
            
            if (Object.keys(portfolio).length === 0) {
                portfolioDiv.innerHTML = '<p style="color: #999;">No holdings yet</p>';
            } else {
                portfolioDiv.innerHTML = '';
                for (let [symbol, amount] of Object.entries(portfolio)) {
                    const value = (amount * marketPrices[symbol]).toFixed(2);
                    const item = document.createElement('div');
                    item.className = 'portfolio-item';
                    item.innerHTML = `
                        <strong>${cryptoNames[symbol]} (${symbol})</strong>
                        <div>
                            <div>${amount} coins</div>
                            <div style="color: #28a745;">$${value}</div>
                        </div>
                    `;
                    portfolioDiv.appendChild(item);
                }
            }
            
            updateNetWorth();
        }
        
        // Event listener for crypto selection change
        document.getElementById('cryptoSelect').addEventListener('change', updateCurrentPriceDisplay);
        
        // Initialize prices and start updates
        function init() {
            // Set initial prices
            marketPrices = {
                BTC: 52000,
                ETH: 3200,
                BNB: 420,
                SOL: 110,
                DOGE: 0.18
            };
            
            updateMarketDisplay();
            updateCurrentPriceDisplay();
            updateUI();
            
            // Update prices every 3 seconds
            setInterval(() => {
                updatePrices();
                updateCurrentPriceDisplay();
                updateUI();
            }, 3000);
        }
        
        // Start the app
        init();
    </script>
</body>
</html>
